import { useState, useEffect } from 'react';
import { useNavigate } from 'react-router-dom';
import { Users, TrendingUp, AlertCircle, BarChart3, Target, ChevronDown, ChevronUp, Flag } from 'lucide-react';
import { db } from '../firebase';
import { collection, getDocs, query, where, orderBy, limit } from 'firebase/firestore';
import { useAuth } from '../context/AuthContext';
import './Dashboard.css';

export default function Dashboard() {
  const [reports, setReports] = useState([]);
  const [loading, setLoading] = useState(true);
  
  // New States for V3.2 features
  const [showVision, setShowVision] = useState(false);
  const [personalKgi, setPersonalKgi] = useState(null);
  const [monthlyResults, setMonthlyResults] = useState(null);

  const navigate = useNavigate();
  const { user } = useAuth();

  useEffect(() => {
    const fetchDashboardData = async () => {
      try {
        // Fetch teams to build hierarchy
        const teamsSnapshot = await getDocs(collection(db, 'teams'));
        const teamsList = [];
        teamsSnapshot.forEach(doc => teamsList.push({ id: doc.id, ...doc.data() }));

        const usersSnapshot = await getDocs(collection(db, 'users'));
        const usersList = [];
        usersSnapshot.forEach((doc) => {
          usersList.push({ uid: doc.id, ...doc.data() });
        });

        // 1. Fetch Reports
        let q;
        if (user.role === 'leader') {
          q = query(collection(db, 'reports'), where('userId', '==', user.uid));
        } else {
          q = query(collection(db, 'reports'), orderBy('createdAt', 'desc'), limit(500));
        }
        const querySnapshot = await getDocs(q);
        const allReports = [];
        querySnapshot.forEach((doc) => {
          allReports.push({ id: doc.id, ...doc.data() });
        });

        const latestReportsMap = {};
        allReports.forEach(r => {
          const uid = r.userId || r.userName;
          if (!uid) return;
          if (!latestReportsMap[uid] || (r.updatedAt > latestReportsMap[uid].updatedAt)) {
            latestReportsMap[uid] = r;
          }
        });

        // 2. Fetch Personal KGI targets
        const d = new Date();
        const currentMonth = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
        const kpiQuery = query(collection(db, 'kpiTargets'), where('userId', '==', user.uid), where('targetMonth', '==', currentMonth), limit(1));
        const kpiSnap = await getDocs(kpiQuery);
        if (!kpiSnap.empty) {
          setPersonalKgi(kpiSnap.docs[0].data());
        } else {
          // Fallback fetch latest approved if any
          const lastKpiQuery = query(collection(db, 'kpiTargets'), where('userId', '==', user.uid), orderBy('targetMonth', 'desc'), limit(1));
          const lastKpiSnap = await getDocs(lastKpiQuery);
          if (!lastKpiSnap.empty) {
            setPersonalKgi(lastKpiSnap.docs[0].data());
          }
        }

        // 3. Fetch Monthly Close Data for current month overview
        if (user.role === 'executive' || user.role === 'manager') {
          const closeQ = query(collection(db, 'monthlyClose'), orderBy('targetMonth', 'desc'), limit(1));
          const closeSnap = await getDocs(closeQ);
          if (!closeSnap.empty) {
            setMonthlyResults(closeSnap.docs[0].data());
          }
        }

        const now = Date.now();
        const SEVEN_DAYS_MS = 7 * 24 * 60 * 60 * 1000;

        let visibleUsers = usersList;

        if (user?.role === 'manager') {
          const managedTeamIds = new Set();
          
          const findChildren = (parentId) => {
            const children = teamsList.filter(t => t.parentId === parentId);
            children.forEach(child => {
              managedTeamIds.add(child.id);
              findChildren(child.id);
            });
          };

          const directManagedTeams = teamsList.filter(t => t.managerId === user.uid);
          directManagedTeams.forEach(t => {
            managedTeamIds.add(t.id);
            findChildren(t.id);
          });

          visibleUsers = usersList.filter(u => 
            u.uid === user.uid || managedTeamIds.has(u.teamId)
          );
        } else if (user?.role === 'leader') {
          visibleUsers = usersList.filter(u => u.uid === user.uid);
        }

        const processedReports = visibleUsers.map(u => {
          const r = latestReportsMap[u.uid] || null;
          
          let isSubmitted = false;
          let weeklyGrossProfit = 0;
          let roi = 0;
          let weeklyOrders = 0;
          let dateStr = '-';
          let reportId = null;

          if (r) {
            isSubmitted = (now - (r.updatedAt || 0)) < SEVEN_DAYS_MS;
            dateStr = r.date || '-';
            reportId = r.id;
            
            const fd = r.formData || {};
            const monthlyCost = Number(fd.orgMembers || 0) * Number(fd.monthlyCostPerMember || 0);
            const mDays = Number(fd.monthlyWorkingDays) || 1;
            const wDays = Number(fd.weeklyWorkingDays) || 0;
            const weeklyCost = monthlyCost ? Math.floor(monthlyCost * (wDays / mDays)) : 0;
            
            roi = (weeklyCost > 0 && fd.weeklyGrossProfit) ? (fd.weeklyGrossProfit / weeklyCost).toFixed(2) : 0;
            weeklyGrossProfit = fd.weeklyGrossProfit || 0;
            weeklyOrders = fd.weeklyOrders || 0;
          }

          return {
            id: u.uid,
            reportId: reportId,
            userName: u.name || '蜷榊燕譛ｪ險ｭ螳・,
            branch: u.branch || '蝟ｶ讌ｭ驛ｨ',
            title: u.title || '荳闊ｬ',
            status: isSubmitted ? '謠仙・貂・ : '譛ｪ謠仙・',
            weeklyGrossProfit: weeklyGrossProfit,
            roi: roi,
            weeklyOrders: weeklyOrders,
            date: dateStr
          };
        });

        setReports(processedReports);
      } catch (error) {
        console.error("Error fetching dashboard data:", error);
      } finally {
        setLoading(false);
      }
    };

    fetchDashboardData();
  }, [user]);

  if (loading) {
    return <div style={{padding: '3rem', textAlign: 'center'}}>繝・・繧ｿ繧帝寔險井ｸｭ...</div>;
  }

  const totalOrders = reports.reduce((sum, r) => sum + Number(r.weeklyOrders || 0), 0);
  const totalGross = reports.reduce((sum, r) => sum + Number(r.weeklyGrossProfit || 0), 0);
  
  const avgRoi = reports.length > 0 
    ? (reports.reduce((sum, r) => sum + Number(r.roi), 0) / reports.length).toFixed(2) 
    : 0;

  const kpiStats = [
    { label: '邨・ｹ泌・菴・蜿玲ｳｨ莉ｶ謨ｰ・域怙譁ｰ騾ｱ・・, value: `${totalOrders}莉ｶ`, subtext: '蜈ｨ雋ｬ莉ｻ閠・・蜷郁ｨ・, icon: <Target style={{ color: '#3b82f6' }} /> },
    { label: '邨・ｹ泌・菴・邊怜茜・域怙譁ｰ騾ｱ・・, value: `${totalGross} P`, subtext: '荳・・謠帷ｮ・, icon: <TrendingUp style={{ color: '#10b981' }} /> },
    { label: '蟷ｳ蝮・ｱ髢迭OI', value: `${avgRoi} 蛟港, subtext: '蜈ｨ雋ｬ莉ｻ閠・・蟷ｳ蝮・, icon: <BarChart3 style={{ color: '#ef4444' }} /> },
  ];

  const getHeaderTitle = () => {
    if (user?.role === 'executive') return '蜈ｨ遉ｾ邱丞粋繝繝・す繝･繝懊・繝・;
    if (user?.role === 'manager') return '繝√・繝繝繝・す繝･繝懊・繝・;
    return '繝槭う繝繝・す繝･繝懊・繝・(KGI/KPI讎りｦ・';
  };

  const getHeaderDesc = () => {
    if (user?.role === 'executive') return '蜈ｨ邨・ｹ斐・繧ｵ繝槭Μ繝ｼ・亥・遉ｾ讎りｦ√・蝠・攝蛻･讒区・・・;
    if (user?.role === 'manager') return '閾ｪ繝√・繝縺ｮ繧ｵ繝槭Μ繝ｼ・医メ繝ｼ繝讎りｦ√・讒区・・・;
    return '蛟倶ｺｺ縺ｮ繝代ヵ繧ｩ繝ｼ繝槭Φ繧ｹ讎りｦ√→諡・ｽ灘膚譚・;
  };

  return (
    <div className="dashboard">
      <div className="dashboard-header" style={{ marginBottom: '1.5rem' }}>
        <h1>{getHeaderTitle()}</h1>
        <p>{getHeaderDesc()}</p>
      </div>

      {/* VISION & MISSION Section */}
      <div className="glass-panel" style={{ marginBottom: '2rem', border: '1px solid var(--border-color)', borderRadius: '8px', overflow: 'hidden' }}>
        <button 
          onClick={() => setShowVision(!showVision)} 
          style={{ width: '100%', display: 'flex', justifyContent: 'space-between', alignItems: 'center', padding: '1rem 1.5rem', background: 'var(--bg-secondary)', border: 'none', cursor: 'pointer', textAlign: 'left' }}
        >
          <div style={{ display: 'flex', alignItems: 'center', gap: '0.5rem', fontWeight: 'bold', color: 'var(--text-primary)' }}>
            <Flag size={18} style={{ color: 'var(--accent-primary)' }} />
            莨夂､ｾ縺ｮVISION繝ｻMISSION
          </div>
          {showVision ? <ChevronUp size={20} /> : <ChevronDown size={20} />}
        </button>
        {showVision && (
          <div style={{ padding: '1.5rem', background: 'var(--bg-primary)', borderTop: '1px solid var(--border-color)', animation: 'fadeIn 0.3s ease-in-out' }}>
            <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '2rem' }}>
              <div>
                <h3 style={{ color: 'var(--accent-primary)', marginBottom: '0.5rem' }}>VISION</h3>
                <p style={{ lineHeight: '1.6', color: 'var(--text-secondary)' }}>
                  繧ｻ繝ｼ繝ｫ繧ｹ縺ｮ蜉帙ｒ譛螟ｧ蛹悶＠縲√☆縺ｹ縺ｦ縺ｮ莨∵･ｭ縺梧戟縺､繝昴ユ繝ｳ繧ｷ繝｣繝ｫ繧貞ｼ輔″蜃ｺ縺吶・                  遘√◆縺｡縺ｯ谺｡荳紋ｻ｣縺ｮ蝟ｶ讌ｭ繝励Λ繝・ヨ繝輔か繝ｼ繝繧帝壹§縺ｦ縲∵戟邯壼庄閭ｽ縺ｪ謌宣聞縺ｨ謌仙粥繧呈髪謠ｴ縺励∪縺吶・                </p>
              </div>
              <div>
                <h3 style={{ color: 'var(--accent-primary)', marginBottom: '0.5rem' }}>MISSION</h3>
                <ul style={{ lineHeight: '1.6', color: 'var(--text-secondary)', paddingLeft: '1.5rem' }}>
                  <li>繝・・繧ｿ繝峨Μ繝悶Φ縺ｪ蝟ｶ讌ｭ豢ｻ蜍輔・謗ｨ騾ｲ</li>
                  <li>螻樔ｺｺ蛹悶・謗帝勁縺ｨ繝√・繝蜈ｨ菴薙・繧ｹ繧ｭ繝ｫ蠎穂ｸ翫￡</li>
                  <li>蟶ｸ縺ｫ螟牙喧縺吶ｋ蟶ょｴ縺ｸ縺ｮ菫頑撫縺ｪ蟇ｾ蠢・/li>
                </ul>
              </div>
            </div>
          </div>
        )}
      </div>

      {/* Personal KGI Section */}
      <div className="glass-panel" style={{ marginBottom: '2rem', padding: '1.5rem', background: 'linear-gradient(135deg, #f0fdfa 0%, #e0f2fe 100%)', border: '1px solid #bae6fd' }}>
        <h3 style={{ marginBottom: '1rem', color: '#0369a1', display: 'flex', alignItems: 'center', gap: '0.5rem' }}>
          <Target size={20} /> 蛟倶ｺｺKGI・井ｻ頑怦縺ｮ逶ｮ讓吶→騾ｲ謐暦ｼ・        </h3>
        {personalKgi ? (
          <div style={{ display: 'flex', gap: '2rem', flexWrap: 'wrap' }}>
            <div style={{ background: 'white', padding: '1rem', borderRadius: '8px', minWidth: '150px', boxShadow: '0 2px 5px rgba(0,0,0,0.05)' }}>
              <div style={{ fontSize: '0.85rem', color: 'var(--text-secondary)' }}>逶ｮ讓吝女豕ｨ莉ｶ謨ｰ ({personalKgi.targetMonth})</div>
              <div style={{ fontSize: '1.75rem', fontWeight: 'bold', color: '#0284c7' }}>{personalKgi.monthlyOrderTarget} <span style={{ fontSize: '1rem' }}>莉ｶ</span></div>
            </div>
            <div style={{ background: 'white', padding: '1rem', borderRadius: '8px', minWidth: '150px', boxShadow: '0 2px 5px rgba(0,0,0,0.05)' }}>
              <div style={{ fontSize: '0.85rem', color: 'var(--text-secondary)' }}>蠢・ｦ∫ｷ乗楔髮ｻ謨ｰ</div>
              <div style={{ fontSize: '1.75rem', fontWeight: 'bold', color: 'var(--text-primary)' }}>{personalKgi.calculatedTargets?.requiredTotalCalls || '-'} <span style={{ fontSize: '1rem' }}>莉ｶ</span></div>
            </div>
            <div style={{ background: 'white', padding: '1rem', borderRadius: '8px', flex: 1, minWidth: '250px', boxShadow: '0 2px 5px rgba(0,0,0,0.05)' }}>
              <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: '0.5rem' }}>
                <span style={{ fontSize: '0.85rem', color: 'var(--text-secondary)' }}>譛磯俣蜿玲ｳｨ騾ｲ謐・/span>
                <span style={{ fontWeight: 'bold', color: '#10b981' }}>{personalKgi.monthlyOrderTarget ? Math.round((totalOrders / personalKgi.monthlyOrderTarget) * 100) : 0}%</span>
              </div>
              <div style={{ width: '100%', background: '#e5e7eb', height: '12px', borderRadius: '6px', overflow: 'hidden' }}>
                <div style={{ width: `${Math.min(100, personalKgi.monthlyOrderTarget ? (totalOrders / personalKgi.monthlyOrderTarget) * 100 : 0)}%`, background: '#10b981', height: '100%' }}></div>
              </div>
              <div style={{ fontSize: '0.8rem', color: 'var(--text-secondary)', marginTop: '0.5rem' }}>
                迴ｾ蝨ｨ {totalOrders}莉ｶ / 逶ｮ讓・{personalKgi.monthlyOrderTarget}莉ｶ
              </div>
            </div>
          </div>
        ) : (
          <p style={{ color: 'var(--text-secondary)' }}>莉頑怦縺ｮKGI逶ｮ讓吶′險ｭ螳壹＆繧後※縺・∪縺帙ｓ縲・a href="/kgi-setting" style={{ color: 'var(--accent-primary)', textDecoration: 'underline' }}>KGI險ｭ螳夂判髱｢</a>縺九ｉ逕ｳ隲九＠縺ｦ縺上□縺輔＞縲・/p>
        )}
      </div>

      {/* Monthly Final Results (Manager/Executive only) */}
      {(user.role === 'executive' || user.role === 'manager') && monthlyResults && (
        <div className="glass-panel" style={{ marginBottom: '2rem', padding: '1.5rem', border: '1px solid #fcd34d' }}>
          <h3 style={{ marginBottom: '1rem', color: '#d97706', display: 'flex', alignItems: 'center', gap: '0.5rem' }}>
            <TrendingUp size={20} /> 蜑肴怦譛邨らｵ先棡繧ｵ繝槭Μ繝ｼ ({monthlyResults.targetMonth})
          </h3>
          <div style={{ display: 'flex', gap: '2rem', flexWrap: 'wrap' }}>
            <div>
              <div style={{ fontSize: '0.85rem', color: 'var(--text-secondary)' }}>譛邨る＃謌千ｲ怜茜</div>
              <div style={{ fontSize: '1.5rem', fontWeight: 'bold', color: 'var(--text-primary)' }}>{Number(monthlyResults.finalGrossProfit).toLocaleString()} <span style={{ fontSize: '1rem' }}>P</span></div>
            </div>
            <div>
              <div style={{ fontSize: '0.85rem', color: 'var(--text-secondary)' }}>譛邨ら捩蝨ｰ莉ｶ謨ｰ</div>
              <div style={{ fontSize: '1.5rem', fontWeight: 'bold', color: 'var(--text-primary)' }}>{Number(monthlyResults.finalOrders).toLocaleString()} <span style={{ fontSize: '1rem' }}>莉ｶ</span></div>
            </div>
            <div>
              <div style={{ fontSize: '0.85rem', color: 'var(--text-secondary)' }}>譛磯俣ROI螳溽ｸｾ</div>
              <div style={{ fontSize: '1.5rem', fontWeight: 'bold', color: 'var(--text-primary)' }}>{monthlyResults.finalRoi} <span style={{ fontSize: '1rem' }}>蛟・/span></div>
            </div>
          </div>
        </div>
      )}

      <div className="stats-grid" style={{ marginBottom: '2rem' }}>
        {kpiStats.map((stat, i) => (
          <div key={i} className="stat-card glass-panel" style={{ padding: '1.5rem' }}>
            <div className="stat-icon" style={{ marginBottom: '1rem' }}>{stat.icon}</div>
            <div className="stat-info">
              <h3 style={{ fontSize: '1rem', color: 'var(--text-secondary)' }}>{stat.label}</h3>
              <p className="stat-value" style={{ fontSize: '2rem', fontWeight: 700, margin: '0.5rem 0' }}>{stat.value}</p>
              <p className="stat-subtext text-muted" style={{fontSize: '0.8rem', color: 'var(--text-secondary)'}}>{stat.subtext}</p>
            </div>
          </div>
        ))}
      </div>

      <div className="reports-section glass-panel" style={{ padding: '2rem' }}>
        <div className="section-header" style={{ marginBottom: '1.5rem' }}>
          <h2>{user?.role === 'leader' ? '譛譁ｰ縺ｮ謠仙・繝・・繧ｿ' : '蜷・ｲｬ莉ｻ閠・・繝｡繝ｳ繝舌・縺ｮ迥ｶ豕・ｼ育峩霑代・謠仙・・・}</h2>
        </div>
        
        <div className="table-container" style={{ overflowX: 'auto' }}>
          <table className="reports-table" style={{ minWidth: '800px', width: '100%' }}>
            <thead>
              <tr>
                <th>雋ｬ莉ｻ閠・錐</th>
                <th>莉企ｱ縺ｮ邊怜茜</th>
                <th>騾ｱ髢迭OI</th>
                <th>謠仙・繧ｹ繝・・繧ｿ繧ｹ</th>
                <th>譛邨よ署蜃ｺ譌･譎・/th>
                <th>繧｢繧ｯ繧ｷ繝ｧ繝ｳ</th>
              </tr>
            </thead>
            <tbody>
              {reports.length === 0 ? (
                <tr>
                  <td colSpan="6" style={{textAlign: 'center', padding: '2rem'}}>
                    縺ｾ縺繝・・繧ｿ縺後≠繧翫∪縺帙ｓ縲・                  </td>
                </tr>
              ) : (
                reports.map(report => (
                  <tr key={report.id}>
                    <td>
                      <div style={{fontWeight: 'bold'}}>{report.userName}</div>
                      <div style={{fontSize: '0.8rem', color: 'var(--text-secondary)'}}>{report.branch} / {report.title}</div>
                    </td>
                    <td style={{fontWeight: 'bold'}}>{report.weeklyGrossProfit} P</td>
                    <td>{report.roi} 蛟・/td>
                    <td>
                      <span className={`status-badge ${report.status === '謠仙・貂・ ? 'success' : 'warning'}`} style={{ padding: '0.25rem 0.5rem', borderRadius: '9999px', fontSize: '0.8rem' }}>
                        {report.status}
                      </span>
                    </td>
                    <td>{report.date}</td>
                    <td>
                      <button 
                        className="btn btn-secondary btn-sm" 
                        disabled={!report.reportId}
                        onClick={() => navigate(`/dashboard/report/${report.reportId}`)}
                        style={{ padding: '0.4rem 0.8rem', fontSize: '0.85rem' }}
                      >
                        {report.reportId ? '隧ｳ邏ｰ繝ｻPDCA繧定ｦ九ｋ' : '謠仙・繝・・繧ｿ縺ｪ縺・}
                      </button>
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  );
}
