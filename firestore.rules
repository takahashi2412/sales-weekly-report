rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() { return request.auth != null; }
    function getRole() { return request.auth.token.role; }
    function isExecutive() { return isAuthenticated() && getRole() == 'executive'; }
    function isManagerOrAbove() { return isAuthenticated() && (getRole() == 'executive' || getRole() == 'manager'); }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    function isInMyTeam(targetUserId) {
      let myTeamId = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId;
      let targetTeamId = get(/databases/$(database)/documents/users/$(targetUserId)).data.teamId;
      return myTeamId != null && myTeamId != '' && targetTeamId != null && targetTeamId != '' && myTeamId == targetTeamId;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, delete: if isExecutive();
      allow update: if isOwner(userId) && !('role' in request.resource.data.diff(resource.data).affectedKeys()) || isExecutive();
    }
    match /teams/{teamId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isExecutive();
    }
    match /productMasters/{productId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isExecutive();
    }
    match /userProductAssignments/{assignmentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isManagerOrAbove());
      allow create, update: if isManagerOrAbove();
      allow delete: if isExecutive();
    }
    match /dailyKpi/{docId} {
      allow read: if isExecutive();
      allow read: if isAuthenticated() && getRole() == 'manager';
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && getRole() == 'leader' && isInMyTeam(resource.data.userId);
      allow create, update: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isManagerOrAbove());
      allow delete: if isExecutive();
    }
    match /dailyKpiSummary/{summaryId} {
      allow read: if isAuthenticated();
      allow create, update: if isManagerOrAbove();
      allow delete: if isExecutive();
    }
    match /kpiTargets/{docId} {
      allow read: if isExecutive();
      allow read: if isAuthenticated() && getRole() == 'manager';
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && getRole() == 'leader' && isInMyTeam(resource.data.userId);
      allow create, update: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isManagerOrAbove());
      allow delete: if isExecutive();
    }
    match /reports/{docId} {
      allow read: if isExecutive();
      allow read: if isAuthenticated() && getRole() == 'manager';
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && getRole() == 'leader' && isInMyTeam(resource.data.userId);
      allow create, update: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isManagerOrAbove());
      allow delete: if isExecutive();
    }
    match /dailyReports/{docId} {
      allow read: if isExecutive();
      allow read: if isAuthenticated() && getRole() == 'manager';
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && getRole() == 'leader' && isInMyTeam(resource.data.userId);
      allow create, update: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isManagerOrAbove());
      allow delete: if isExecutive();
    }
    match /improveTasks/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.assignedBy == request.auth.uid || isManagerOrAbove());
      allow create, update: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isManagerOrAbove());
      allow delete: if isExecutive();
    }
    match /educationRecords/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isManagerOrAbove());
      allow create, update: if isManagerOrAbove();
      allow delete: if isExecutive();
    }
    match /training_records/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isManagerOrAbove());
      allow create, update: if isManagerOrAbove();
      allow delete: if isExecutive();
    }
    match /monthlyClose/{docId} {
      allow read: if isExecutive();
      allow read: if isAuthenticated() && getRole() == 'manager';
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && getRole() == 'leader' && isInMyTeam(resource.data.userId);
      allow create, update: if isExecutive();
      allow delete: if false;
    }
    match /csvImportLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isManagerOrAbove();
      allow update: if isExecutive();
      allow delete: if false;
    }
    match /auditLogs/{logId} {
      allow read: if isExecutive();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
    match /notifications/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isManagerOrAbove());
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create, delete: if false;
    }
    match /aiAnalysis/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isManagerOrAbove());
      allow write: if false;
    }
    match /alerts/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isManagerOrAbove());
      allow write: if false;
    }
    match /orders/{orderId} {
      allow read: if isExecutive();
      allow read: if isAuthenticated() && getRole() == 'manager';
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && getRole() == 'leader' && isInMyTeam(resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        (resource.data.status == 'provisional' && request.resource.data.userId == request.auth.uid) ||
        (resource.data.status == 'confirmed' && isExecutive())
      );
      allow delete: if isAuthenticated() && resource.data.status == 'provisional' && resource.data.userId == request.auth.uid;
    }
  }
}
